import unittest
from unittest.mock import patch, MagicMock
import pandas as pd
from g.My_Drive.dev.nairraks.github.io.etf_portfolio.curation import justetf_scraping

# File: test_curation.py

class TestCuration(unittest.TestCase):
    @patch("g.My_Drive.dev.nairraks.github.io.etf_portfolio.curation.justetf_scraping.load_overview")
    @patch("pandas.DataFrame.to_csv")
    def test_scrape_etf_data(self, mock_to_csv, mock_load_overview):
        # Mock data
        mock_df = pd.DataFrame({"column1": [1, 2], "column2": [3, 4]})
        mock_load_overview.return_value = mock_df

        # Mock country_df
        country_df = pd.DataFrame({
            "Short_name": ["US", "CN"]
        })

        # Asset classes
        asset_classes = ["class-equity"]

        # Run the scraping loop
        for asset_class in asset_classes:
            for short_name in country_df["Short_name"]:
                try:
                    df = justetf_scraping.load_overview(asset_class=asset_class, country=short_name, local_country="GB")
                    filename = f'justetf_{asset_class}_{short_name}.csv'
                    df.to_csv(filename, index=False)
                except Exception as e:
                    self.fail(f"Exception occurred: {e}")

        # Assertions
        self.assertEqual(mock_load_overview.call_count, 2)  # Called for each short_name
        mock_to_csv.assert_called()  # Ensure to_csv was called
        mock_to_csv.assert_any_call("justetf_class-equity_US.csv", index=False)
        mock_to_csv.assert_any_call("justetf_class-equity_CN.csv", index=False)

if __name__ == "__main__":
    unittest.main()