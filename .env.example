# Historical-price data provider.
#   "alphavantage" — PREFERRED: cleaner corporate-action handling on LSE
#                    listings. All reported numbers in the book use this.
#                    Requires ALPHAVANTAGE_API_KEY below.
#   "yfinance"     — Fallback: free, no API key. Results can differ at the
#                    last decimal place from AlphaVantage.
DATA_PROVIDER=alphavantage

# AlphaVantage API key — required when DATA_PROVIDER=alphavantage.
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_key_here

# FRED API key — required for SONIA-based dynamic risk-free/base-rate lookups
# in notebook 04 performance tracking. Get one at:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here

# Annualised risk-free rate used as the default in Sharpe ratio calculations.
# Expressed as a fraction (e.g. 0.04 = 4%). Default is 0.0.
RISK_FREE_RATE=0.0

# Trading212 API credentials — only needed if you want the screener to check
# Trading212 availability alongside InvestEngine. Obtain from your Trading212
# account settings (Settings → API → Generate key). If either is missing the
# Trading212 check is silently skipped and only InvestEngine is queried.
TRADING212_API_KEY=your_t212_key_here
TRADING212_API_SECRET=your_t212_secret_here
