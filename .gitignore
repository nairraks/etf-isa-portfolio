# Secrets — never commit
.env

# Jupyter Book build outputs
_build/
.jupyter_cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
*.egg-info/

# Archive — legacy notebooks with hardcoded API keys
archive/

# Intermediate/output CSVs — DB is authoritative (commit DB after pipeline runs)
data/raw/*.csv
data/intermediate/*.csv
data/output/final_portfolio.csv

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Gemini/AI local knowledge
.gemini/
.claude/

# Temporary and Cache Directories
tmp/
data/cache/
notebooks/data/

# Backup Files
*.bak

# Scratch scripts and temporary files
scratch/
scripts/
notebooks/*.py
out.txt
cols.txt
ie_api_results.json
